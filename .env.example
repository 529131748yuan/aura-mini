# ==========================================
# Aura AI 配置
# ==========================================

AURA_AI_PROVIDER=deepseek

# DeepSeek API Key，请在腾讯云环境变量里配置真实值，不要提交真实 Key
AURA_AI_API_KEY=your_api_key_here

# DeepSeek 官方接口
AURA_AI_BASE_URL=https://api.deepseek.com

# 默认模型
AURA_AI_MODEL=deepseek-chat

# 今日状态分析（速度优先）
AURA_TODAY_MODEL=deepseek-chat

# 完整人生档案（推理能力优先）
AURA_PROFILE_MODEL=deepseek-reasoner

# 众生社区 AI 点评
AURA_COMMUNITY_MODEL=deepseek-chat

# AI 大师解惑
AURA_MASTER_MODEL=deepseek-reasoner

# ==========================================
# 腾讯云
# ==========================================

TENCENT_DEPLOY_TARGET=cloudbase
